{
  "manifest_version": 3,
  "name": "ManipDetect AI",
  "short_name": "ManipDetect",
  "version": "1.0",
  "description": "Detects manipulative content on any webpage using AI.",

  "permissions": ["activeTab", "scripting"],

  "host_permissions": [
    "http://localhost:5000/*",
    "https://*.ngrok.io/*",
    "https://*.ngrok-free.dev/*"
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "ManipDetect AI",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}